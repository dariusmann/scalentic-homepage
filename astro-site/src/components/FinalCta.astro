---
import { BOOKING_URL, EMAIL } from '../consts';
import LinkedInButton from './LinkedInButton.astro';
---

<section id="contact">
  <div class="shell inner">
    <h2>Let's take the busywork<br />off your plate.</h2>
    <p>A short call is all it takes to find the first thing worth automating.</p>
    <div class="cta">
      <a class="btn btn-primary" href={BOOKING_URL} target="_blank" rel="noopener">Book a call</a>
      <a class="btn btn-ghost" href={`mailto:${EMAIL}`}>{EMAIL}</a>
      <LinkedInButton />
    </div>
  </div>
</section>

<style>
  .inner {
    padding-top: 128px;
    padding-bottom: 128px;
    text-align: center;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 5.6vw, 80px);
    line-height: 1.06;
    letter-spacing: -0.018em;
    color: var(--text-bright);
    max-width: 900px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .inner > p {
    font-family: var(--serif);
    font-size: clamp(18px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--muted);
    max-width: 520px;
    margin: 26px auto 0;
  }
  .cta {
    display: flex;
    gap: 13px;
    justify-content: center;
    align-items: center;
    margin-top: 38px;
    flex-wrap: wrap;
  }
  .btn-primary,
  .btn-ghost {
    padding: 15px 30px;
  }
</style>
