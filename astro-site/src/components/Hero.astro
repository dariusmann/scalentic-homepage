---
import { BOOKING_URL } from '../consts';
import type { Campaign } from '../campaigns';

interface Props {
  hero: Campaign['hero'];
}

const { hero } = Astro.props;
---

<header>
  <div class="shell grid">
    <div class="copy">
      <h1>
        {
          hero.headlineLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h1>
      <p>{hero.description}</p>
      <div class="cta">
        <a class="btn btn-primary" href={BOOKING_URL} target="_blank" rel="noopener">Book a call</a>
        <a class="btn btn-ghost" href="#automate">See what we automate</a>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <span class="tag">OUTPUT VS. TEAM</span>
        <span class="live"><span class="dot"></span>LIVE</span>
      </div>
      <div class="panel-body">
        <span class="legend out"><i></i>Output</span>
        <span class="legend team"><i></i>Team</span>
        <span class="mult" data-mult>×1.0</span>
        <canvas class="chart" data-output-chart></canvas>
      </div>
    </div>
  </div>
</header>

<style>
  header {
    position: relative;
    border-bottom: 1px solid var(--line);
  }
  .grid {
    padding-top: 110px;
    padding-bottom: 96px;
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    gap: 72px;
    align-items: center;
  }
  .copy {
    max-width: 720px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(36px, 4.6vw, 58px);
    line-height: 1.08;
    letter-spacing: -0.018em;
    color: var(--text-bright);
  }
  .copy p {
    font-family: var(--serif);
    font-size: clamp(18px, 1.5vw, 21px);
    line-height: 1.62;
    color: var(--text-soft);
    max-width: 520px;
    margin-top: 28px;
  }
  .cta {
    display: flex;
    gap: 13px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .panel {
    position: relative;
    border: 1px solid var(--line-strong);
    border-radius: 16px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0));
    box-shadow: 0 30px 80px -40px rgba(0, 0, 0, 0.85);
    animation: panelIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 18px;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .tag {
    position: relative;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: #8a887f;
    background: linear-gradient(
      90deg,
      #8a887f 0%,
      #8a887f 38%,
      #f4f3ee 50%,
      #8a887f 62%,
      #8a887f 100%
    );
    background-size: 220% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    animation: tagShimmer 3.2s ease-in-out infinite;
  }
  .tag::after {
    content: '';
    position: absolute;
    right: -10px;
    top: 50%;
    width: 6px;
    height: 1.1em;
    background: #f0efea;
    transform: translateY(-50%);
    animation: tagCursor 1.05s step-end infinite;
  }
  .live {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--text);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text);
    animation: scDot 1.8s ease-in-out infinite;
  }
  .panel-body {
    position: relative;
    height: 300px;
  }
  .chart {
    display: block;
    width: 100%;
    height: 100%;
  }
  .legend {
    position: absolute;
    left: 18px;
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    z-index: 2;
  }
  .legend i {
    display: inline-block;
    width: 18px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
  }
  .legend.out {
    top: 16px;
    color: var(--text-bright);
  }
  .legend.team {
    bottom: 12px;
    color: #8a887f;
  }
  .mult {
    position: absolute;
    top: 13px;
    right: 18px;
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-bright);
    font-variant-numeric: tabular-nums;
    z-index: 2;
  }

  @keyframes panelIn {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes tagShimmer {
    0%,
    100% {
      background-position: 120% 0;
    }
    50% {
      background-position: -20% 0;
    }
  }
  @keyframes tagCursor {
    0%,
    45% {
      opacity: 1;
    }
    46%,
    100% {
      opacity: 0;
    }
  }
  @keyframes scDot {
    0%,
    100% {
      opacity: 0.3;
      transform: scale(0.8);
    }
    50% {
      opacity: 1;
      transform: scale(1.15);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .panel,
    .tag,
    .dot {
      animation: none !important;
    }
    .tag::after {
      display: none;
    }
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-top: 72px;
      padding-bottom: 64px;
    }
  }
</style>

<script is:inline>
  const ease = (x) => {
    x = Math.max(0, Math.min(1, x));
    return x * x * (3 - 2 * x);
  };

  function initOutputChart(canvas) {
    if (canvas.dataset.chartInit) return;
    canvas.dataset.chartInit = '1';

    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const multEl = canvas.parentElement?.querySelector('[data-mult]');
    let w = 0;
    let h = 0;
    let lastDp = 0;
    let rafId = 0;

    function fit() {
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function frame(dp) {
      if (w <= 0 || h <= 0) return;
      const padT = 46;
      const padB = 30;
      const x0 = 4;
      const x1 = w - 4;
      const base = h - padB;
      const climb = base - padT;
      const span = x1 - x0;
      const xmax = x0 + span * dp;
      ctx.clearRect(0, 0, w, h);

      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x0, base);
      ctx.lineTo(x1, base);
      ctx.stroke();

      ctx.beginPath();
      for (let x = x0; x <= xmax; x += 3) {
        const xn = (x - x0) / span;
        const y = base - 8 - 6 * xn;
        x === x0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = '#8a887f';
      ctx.lineWidth = 1.6;
      ctx.stroke();

      let ey = base;
      ctx.beginPath();
      for (let x = x0; x <= xmax; x += 3) {
        const xn = (x - x0) / span;
        const y = base - 8 - climb * 0.92 * Math.pow(xn, 2);
        ey = y;
        x === x0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = '#f4f3ee';
      ctx.lineWidth = 2;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(xmax, ey, 3.5, 0, Math.PI * 2);
      ctx.fillStyle = '#f4f3ee';
      ctx.fill();

      if (multEl) multEl.textContent = '×' + (1 + 7 * dp).toFixed(1);
    }

    let start = null;
    function loop(now) {
      if (start === null) start = now;
      const p = (((now - start) / 1000) % 5.5) / 5.5;
      lastDp = ease(Math.min(1, p / 0.8));
      frame(lastDp);
      rafId = requestAnimationFrame(loop);
    }

    function startLoop() {
      fit();
      if (w <= 0 || h <= 0) {
        rafId = requestAnimationFrame(startLoop);
        return;
      }
      start = null;
      rafId = requestAnimationFrame(loop);
    }

    startLoop();

    new ResizeObserver(() => {
      fit();
      frame(lastDp);
    }).observe(canvas);

    return () => {
      cancelAnimationFrame(rafId);
      delete canvas.dataset.chartInit;
    };
  }

  function bootCharts() {
    document.querySelectorAll('[data-output-chart]').forEach(initOutputChart);
  }

  bootCharts();
  document.addEventListener('astro:page-load', bootCharts);
</script>
