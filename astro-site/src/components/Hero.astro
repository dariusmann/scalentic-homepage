---
import { BOOKING_URL } from '../consts';
import type { Campaign } from '../campaigns';

interface Props {
  hero: Campaign['hero'];
}

const { hero } = Astro.props;
---

<header>
  <div class="shell grid">
    <div class="copy">
      <h1>
        {
          hero.headlineLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h1>
      <p>{hero.description}</p>
      <div class="cta">
        <a class="btn btn-primary" href={BOOKING_URL} target="_blank" rel="noopener">Book a call</a>
        <a class="btn btn-ghost" href="#automate">See what we automate</a>
      </div>
    </div>

    <div class="hero-chart">
      <canvas data-output-chart></canvas>
    </div>
  </div>
</header>

<style>
  header {
    position: relative;
    border-bottom: 1px solid var(--line);
  }
  .grid {
    padding-top: 110px;
    padding-bottom: 96px;
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    gap: 72px;
    align-items: center;
  }
  .copy {
    max-width: 720px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(36px, 4.6vw, 58px);
    line-height: 1.08;
    letter-spacing: -0.018em;
    color: var(--text-bright);
  }
  .copy p {
    font-family: var(--serif);
    font-size: clamp(18px, 1.5vw, 21px);
    line-height: 1.62;
    color: var(--text-soft);
    max-width: 520px;
    margin-top: 28px;
  }
  .cta {
    display: flex;
    gap: 13px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .hero-chart {
    position: relative;
    width: 100%;
    height: 340px;
  }
  .hero-chart canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-top: 72px;
      padding-bottom: 64px;
    }
  }
</style>

<script is:inline>
  const ease = (x) => {
    x = Math.max(0, Math.min(1, x));
    return x * x * (3 - 2 * x);
  };
  const OUT = '#f4f3ee';
  const TEAM = '#8a887f';

  function initOutputChart(canvas) {
    if (canvas.dataset.chartInit) return;
    canvas.dataset.chartInit = '1';

    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    let w = 0;
    let h = 0;
    let lastDp = 0;
    let rafId = 0;

    function fit() {
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function frame(dp) {
      if (w <= 0 || h <= 0) return;
      const padT = 44;
      const padB = 40;
      const x0 = 8;
      const x1 = w - 48;
      const base = h - padB;
      const span = x1 - x0;
      const climb = base - padT;
      const xmax = x0 + span * dp;
      ctx.clearRect(0, 0, w, h);

      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x0, base);
      ctx.lineTo(x1, base);
      ctx.stroke();

      ctx.beginPath();
      for (let x = x0; x <= xmax; x += 3) {
        const xn = (x - x0) / span;
        const y = base - 7 - 6 * xn;
        x === x0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = TEAM;
      ctx.lineWidth = 1.6;
      ctx.stroke();

      let ey = base;
      ctx.beginPath();
      for (let x = x0; x <= xmax; x += 3) {
        const xn = (x - x0) / span;
        const y = base - 7 - climb * 0.9 * Math.pow(xn, 2);
        ey = y;
        x === x0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = OUT;
      ctx.lineWidth = 2.4;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(xmax, ey, 4, 0, Math.PI * 2);
      ctx.fillStyle = OUT;
      ctx.fill();

      ctx.font = "500 13px 'Hanken Grotesk', sans-serif";
      ctx.textAlign = 'left';
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle = TEAM;
      ctx.fillText('same team', x0, base + 24);

      const a = ease((dp - 0.5) / 0.32);
      if (a > 0) {
        ctx.globalAlpha = a;
        ctx.strokeStyle = 'rgba(244,243,238,0.5)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(xmax, ey);
        ctx.lineTo(xmax - 48, ey - 32);
        ctx.stroke();
        ctx.font = "500 17px 'Literata', serif";
        ctx.fillStyle = OUT;
        ctx.textAlign = 'right';
        ctx.fillText('8× output', xmax - 8, ey - 38);
        ctx.globalAlpha = 1;
      }
    }

    let start = null;
    function loop(now) {
      if (start === null) start = now;
      const p = (((now - start) / 1000) % 5.5) / 5.5;
      lastDp = ease(Math.min(1, p / 0.8));
      frame(lastDp);
      rafId = requestAnimationFrame(loop);
    }

    function startLoop() {
      fit();
      if (w <= 0 || h <= 0) {
        rafId = requestAnimationFrame(startLoop);
        return;
      }
      start = null;
      rafId = requestAnimationFrame(loop);
    }

    startLoop();

    new ResizeObserver(() => {
      fit();
      frame(lastDp);
    }).observe(canvas);
  }

  function bootCharts() {
    document.querySelectorAll('[data-output-chart]').forEach(initOutputChart);
  }

  bootCharts();
  document.addEventListener('astro:page-load', bootCharts);
</script>
