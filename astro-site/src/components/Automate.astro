---
import type { Campaign } from '../campaigns';

interface Props {
  automate: Campaign['automate'];
}

const { automate } = Astro.props;
---

<section id="automate">
  <div class="shell inner">
    <div class="head">
      <div>
        <span class="eyebrow">What we automate</span>
        <h2>{automate.headline}</h2>
      </div>
      <p class="head-note">{automate.headNote}</p>
    </div>

    <div class="rows">
      {
        automate.items.map((it) => (
          <div class="row">
            <span class="num">{it.n}</span>
            <h3>{it.title}</h3>
            <p>{it.body}</p>
          </div>
        ))
      }
    </div>
    {automate.footNote && <p class="head-note foot-note">{automate.footNote}</p>}
  </div>
</section>

<style>
  section {
    border-bottom: 1px solid var(--line);
  }
  .inner {
    padding-top: 108px;
    padding-bottom: 108px;
  }
  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 56px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(32px, 3.8vw, 52px);
    line-height: 1.12;
    letter-spacing: -0.015em;
    max-width: 620px;
    color: var(--text-bright);
  }
  .head-note {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 300px;
  }
  .foot-note {
    margin-top: 40px;
    max-width: 640px;
  }
  .row {
    display: flex;
    align-items: flex-start;
    gap: 30px;
    padding: 34px 0;
    border-top: 1px solid var(--line-strong);
  }
  .rows .row:last-child {
    border-bottom: 1px solid var(--line-strong);
  }
  .num {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--muted-3);
    width: 40px;
    flex-shrink: 0;
  }
  h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(26px, 2.7vw, 38px);
    line-height: 1.1;
    width: 320px;
    flex-shrink: 0;
    color: var(--text-bright);
  }
  .row p {
    font-family: var(--serif);
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.6;
    color: var(--muted);
    max-width: 520px;
  }
  @media (max-width: 760px) {
    .row {
      flex-direction: column;
      gap: 12px;
    }
    h3 {
      width: auto;
    }
  }
</style>
