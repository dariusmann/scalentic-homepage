---
import { LINKEDIN } from '../consts';

interface Props {
  href?: string;
  label?: string;
}

const { href = LINKEDIN, label = 'LinkedIn profile' } = Astro.props;
---

<a class="linkedin-btn" href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
  <!-- Simple Icons (CC0) — https://simpleicons.org/icons/linkedin.html -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path
      fill="currentColor"
      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
    ></path>
  </svg>
</a>

<style>
  .linkedin-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    color: var(--text);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 11px;
    transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  .linkedin-btn:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.38);
    background: rgba(255, 255, 255, 0.05);
    color: #ffffff;
  }
  .linkedin-btn svg {
    width: 20px;
    height: 20px;
  }
</style>
