---
import { SITE, BOOKING_URL, NAV_LINKS } from '../consts';
---

<nav>
  <div class="shell bar">
    <span class="wordmark">{SITE.wordmark}</span>
    <div class="links">
      {NAV_LINKS.map((l) => <a class="navlink" href={l.href}>{l.label}</a>)}
    </div>
    <a class="btn btn-primary book" href={BOOKING_URL} target="_blank" rel="noopener">Book a call</a>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(12, 12, 13, 0.86);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .bar {
    padding-top: 18px;
    padding-bottom: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .wordmark {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .links {
    display: flex;
    align-items: center;
    gap: 34px;
    font-size: 15px;
    white-space: nowrap;
  }
  .book {
    font-size: 15px;
    padding: 9px 18px;
    border-radius: 9px;
  }
  @media (max-width: 820px) {
    .links {
      display: none;
    }
  }
</style>
