---
import type { Campaign } from '../campaigns';

interface Props {
  customers: Campaign['customers'];
}

const { customers } = Astro.props;
---

<section id="customers">
  <div class="shell inner">
    <span class="eyebrow">Customers</span>
    <h2>{customers.headline}</h2>
    <div class="grid">
      {
        customers.quotes.map((q) => (
          <figure>
            <blockquote>{q.quote}</blockquote>
            <figcaption>
              {q.name}
              <br />
              <span class="role">{q.role}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    border-bottom: 1px solid var(--line);
  }
  .inner {
    padding-top: 108px;
    padding-bottom: 108px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(32px, 3.8vw, 52px);
    line-height: 1.12;
    letter-spacing: -0.015em;
    max-width: 600px;
    margin-bottom: 64px;
    color: var(--text-bright);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  figure {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 28px;
  }
  blockquote {
    font-family: var(--serif);
    font-size: 21px;
    line-height: 1.5;
    color: var(--text);
    margin-bottom: 26px;
  }
  figcaption {
    font-size: 14px;
    color: var(--muted);
  }
  .role {
    color: var(--muted-3);
  }
  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
